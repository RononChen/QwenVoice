{
  "schemaVersion": 1,
  "componentID": "vocello-qwen3-core",
  "package": {
    "name": "MLXAudio",
    "swiftToolsVersion": "6.1",
    "minimumPlatforms": {
      "macOS": "14",
      "iOS": "17"
    },
    "products": [
      "VocelloQwen3Core",
      "MLXAudioCore",
      "MLXAudioCodecs",
      "MLXAudioTTS"
    ],
    "targets": [
      "VocelloQwen3Core",
      "MLXAudioCore",
      "MLXAudioCodecs",
      "MLXAudioTTS",
      "Qwen3RuntimeTests"
    ],
    "directDependencies": {
      "mlx-swift": "0.30.6",
      "mlx-swift-lm": "2.30.6",
      "swift-huggingface": "0.9.0"
    },
    "benchmarkNeutralResolvedDependencies": {
      "swift-nio": "Transitive EventSource transport primitives do not participate in prepared Qwen model loading, tokenization, or synthesis; lockstep, security-baseline, and deterministic build checks still apply."
    }
  },
  "sourceCompatibility": {
    "preferredProduct": "VocelloQwen3Core",
    "preferredImportModule": "VocelloQwen3Core",
    "stableContracts": [
      "VocelloQwen3PreparedModelBundle",
      "VocelloQwen3SynthesisRequest",
      "VocelloQwen3Engine",
      "VocelloQwen3GenerationReservation",
      "VocelloQwen3ClassifiedGenerationSession",
      "VocelloQwen3CloneHandle",
      "VocelloQwen3MemoryReliefAction",
      "VocelloQwen3TerminalOutcome",
      "VocelloQwen3DiagnosticEvent"
    ],
    "temporaryLegacySPI": {
      "name": "VocelloQwen3LegacyCompatibility",
      "status": "shipping-compatibility-only",
      "surfaces": [
        "VocelloQwen3GenerationSignal",
        "VocelloQwen3GenerationCompletion",
        "VocelloQwen3ClonePrompt",
        "VocelloQwen3CompatibilityDiagnostics",
        "VocelloQwen3LoadedModel",
        "VocelloQwen3Engine.init(adoptingCompatibilityModel:)",
        "VocelloQwen3Engine.adoptValidatedClonePrompt",
        "VocelloQwen3Runtime.loadPreparedModel",
        "VocelloQwen3Runtime.clearRuntimeCaches"
      ],
      "consumerAllowlist": [
        "Sources/QwenVoiceCore/MLXModelLoadCoordinator.swift",
        "Sources/QwenVoiceCore/NativeCloneSupport.swift",
        "Sources/QwenVoiceCore/NativeEngineRuntime.swift",
        "Sources/QwenVoiceCore/UnsafeSpeechGenerationModel.swift"
      ],
      "consumerAllowlistEnforcement": "scripts/vendor_runtime_contract.py::LEGACY_COMPATIBILITY_SPI_CONSUMERS",
      "policy": "This named SPI is limited to transitional prepared-model loading, prewarm/conditioning, loaded-model adoption, and validated schema-3 clone-prompt adoption. Custom, Design, and Clone generation run through the public actor and classified session; the SPI is not product generation authority."
    },
    "internalCharacterizationSurfaces": [
      "VocelloQwen3GenerationSession",
      "VocelloQwen3GenerationEvent",
      "VocelloQwen3ModelGenerationSession"
    ],
    "preservedImportModules": [
      "MLXAudioCore",
      "MLXAudioCodecs",
      "MLXAudioTTS"
    ],
    "policy": "Vocello product generation consumes the owned engine actor, classified session, and product finalization contracts. QwenVoiceCore imports the named legacy SPI only for the remaining load/prewarm and schema-3 conditioning bridge. The MLXAudio package, products, targets, modules, and public APIs remain available as implementation compatibility surfaces."
  },
  "modelContract": "../../Sources/Resources/qwenvoice_contract.json",
  "validation": [
    "python3 scripts/vendor_runtime_contract.py validate",
    "scripts/macos_test.sh test"
  ]
}
