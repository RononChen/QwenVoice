# Copy to .gitlab-ci-secrets.env (gitignored) and fill values once.
# Then: source .gitlab-ci-secrets.env && ./scripts/gitlab_setup_all.sh SET_CI_VARS=1

GITLAB_TOKEN=

# Optional — only needed for SET_CI_VARS=1
APPLE_DEV_ID_APP_P12_BASE64=
APPLE_DEV_ID_APP_P12_PASSWORD=
APPLE_NOTARY_KEY_ID=
APPLE_NOTARY_PRIVATE_KEY_P8=
APPLE_NOTARY_ISSUER_ID=
APPLE_TEAM_ID=
GITHUB_MIRROR_TOKEN=
