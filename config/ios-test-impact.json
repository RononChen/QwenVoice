{
  "schemaVersion": 1,
  "defaultRequiredSuites": [],
  "rules": [
    {
      "requiredSuites": ["benchmark", "full"],
      "patterns": [
        "Sources/QwenVoiceBackendCore/**",
        "Sources/QwenVoiceCore/**",
        "Sources/iOSSupport/**",
        "scripts/lib/ios_agent_ui.py",
        "config/ios-ui-scenarios.json"
      ]
    },
    {
      "requiredSuites": ["full"],
      "patterns": [
        "project.yml",
        "Sources/SharedSupport/**",
        "Sources/iOS/**",
        ".agents/skills/vocello-ios-ui-qa/**",
        "scripts/ios_agent_ui.sh",
        "scripts/ios_device.sh"
      ]
    },
    {
      "requiredSuites": ["quick"],
      "patterns": ["Sources/Assets.xcassets/**", "Sources/Resources/voice-previews/**"]
    }
  ]
}
