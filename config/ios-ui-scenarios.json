{
  "schemaVersion": 1,
  "driver": "bundled-computer-use",
  "surface": "com.apple.ScreenContinuity",
  "deviceAppBundleId": "com.patricedery.vocello",
  "defaultTimeoutSeconds": 30,
  "suites": {
    "quick": {
      "budgetMinutes": 15,
      "includes": ["launch-navigation", "studio-controls", "semantic-review"]
    },
    "full": {
      "budgetMinutes": 50,
      "includes": [
        "launch-navigation",
        "model-readiness",
        "studio-controls",
        "semantic-review",
        "custom-generation",
        "design-generation",
        "clone-generation",
        "history-voices-settings"
      ]
    },
    "benchmark": {
      "budgetMinutes": null,
      "includes": ["model-readiness", "generation-matrix"]
    }
  },
  "scenarios": [
    {
      "id": "launch-navigation",
      "title": "Launch and primary-tab navigation through iPhone Mirroring",
      "timeoutSeconds": 120,
      "steps": [
        {"id": "launch", "target": "device bundle com.patricedery.vocello", "result": "Studio is visible"},
        {"id": "studio", "target": "Studio tab", "result": "Studio canvas is visible"},
        {"id": "voices", "target": "Voices tab", "result": "voice library is visible"},
        {"id": "history", "target": "History tab", "result": "History is visible"},
        {"id": "settings", "target": "Settings tab", "result": "model and preference rows are visible"}
      ]
    },
    {
      "id": "model-readiness",
      "title": "Visible model and clone-fixture readiness",
      "timeoutSeconds": 180,
      "steps": [
        {"id": "open-settings", "target": "Settings tab and Model Downloads", "result": "Custom, Design, and Clone model rows are visible"},
        {"id": "custom-ready", "target": "Custom Speed model row", "result": "model visibly reports installed and ready"},
        {"id": "design-ready", "target": "Design Speed model row", "result": "model visibly reports installed and ready"},
        {"id": "clone-ready", "target": "Clone Speed model row", "result": "model visibly reports installed and ready"},
        {"id": "clone-voice-ready", "target": "Saved Voices", "result": "a saved clone reference is visible before Clone or benchmark generation"},
        {"id": "generate-enabled", "target": "Studio Generate", "result": "Generate is visibly enabled after selecting each required mode"}
      ]
    },
    {
      "id": "studio-controls",
      "title": "Studio mode and setup controls",
      "timeoutSeconds": 180,
      "steps": [
        {"id": "custom", "target": "Custom mode", "result": "built-in voice controls and composer are visible"},
        {"id": "design", "target": "Design mode", "result": "voice brief controls and composer are visible"},
        {"id": "clone", "target": "Clone mode", "result": "reference controls and composer are visible"}
      ]
    },
    {
      "id": "semantic-review",
      "title": "Named visual and accessibility review",
      "timeoutSeconds": 240,
      "checks": ["no-clipping", "no-truncation", "readable-copy", "enabled-state", "contrast", "touch-targets"],
      "steps": [
        {"id": "review-studio", "target": "Studio", "result": "named checks pass"},
        {"id": "review-voices", "target": "Voices", "result": "named checks pass"},
        {"id": "review-history", "target": "History", "result": "named checks pass"},
        {"id": "review-settings", "target": "Settings", "result": "named checks pass"}
      ]
    },
    {
      "id": "custom-generation",
      "title": "Custom Voice generation and History proof",
      "timeoutSeconds": 360,
      "fixtureText": "Codex iPhone Custom Voice acceptance generation.",
      "steps": [
        {"id": "compose", "target": "Studio composer", "result": "fixture text is visible"},
        {"id": "generate", "target": "Generate", "result": "completed player is visible"},
        {"id": "history", "target": "History", "result": "matching take is visible"},
        {"id": "verify", "target": "shell telemetry", "result": "matching terminal engine row passes audio QC"}
      ]
    },
    {
      "id": "design-generation",
      "title": "Voice Design generation",
      "timeoutSeconds": 420,
      "fixtureText": "Codex iPhone Voice Design acceptance generation.",
      "steps": [
        {"id": "brief", "target": "Voice brief", "result": "brief is configured"},
        {"id": "compose", "target": "Studio composer", "result": "fixture text is visible"},
        {"id": "generate", "target": "Generate", "result": "completed player is visible"},
        {"id": "verify", "target": "shell telemetry", "result": "matching terminal engine row passes audio QC"}
      ]
    },
    {
      "id": "clone-generation",
      "title": "Saved-reference clone generation",
      "timeoutSeconds": 420,
      "fixtureText": "Codex iPhone Voice Clone acceptance generation.",
      "steps": [
        {"id": "reference", "target": "saved reference", "result": "reference is selected"},
        {"id": "compose", "target": "Studio composer", "result": "fixture text is visible"},
        {"id": "generate", "target": "Generate", "result": "completed player is visible"},
        {"id": "verify", "target": "shell telemetry", "result": "matching terminal engine row passes audio QC"}
      ]
    },
    {
      "id": "history-voices-settings",
      "title": "History, Voices, model, and reversible preference states",
      "timeoutSeconds": 300,
      "steps": [
        {"id": "history", "target": "History", "result": "generated rows replay"},
        {"id": "voices", "target": "Voices", "result": "built-in and saved sections render"},
        {"id": "models", "target": "Settings model rows", "result": "all model states render coherently"},
        {"id": "preferences", "target": "Settings preferences", "result": "reversible controls respond and are restored"}
      ]
    },
    {
      "id": "generation-matrix",
      "title": "Ordered 29-take Computer Use generation benchmark",
      "timeoutSeconds": 10800,
      "matrix": {
        "modes": ["custom", "design", "clone"],
        "lengths": ["short", "medium", "long"],
        "warmRepetitions": 3,
        "coldLength": "medium",
        "coldModes": ["custom", "design"],
        "corpus": {
          "short": "The train left the station at dawn.",
          "medium": "The morning train slipped quietly out of the station, carrying a handful of sleepy travelers toward the coast.",
          "long": "The morning train slipped quietly out of the station, carrying a handful of sleepy travelers toward the coast. Outside the fogged windows, pale fields gave way to grey water, and the rhythm of the rails settled into a steady, hypnotic hum. By the time the sun finally broke through, most of the passengers had drifted into an unhurried silence."
        }
      },
      "steps": [
        {"id": "drive-matrix", "target": "Studio Generate", "result": "29 ordered takes have screenshots and passing telemetry rows"}
      ]
    }
  ]
}
