{
  "schemaVersion": 2,
  "appPath": "build/Vocello.app",
  "defaultTimeoutSeconds": 30,
  "statePolicy": {
    "nonDestructive": "snapshot-and-restore-debug-preferences-and-saved-voices",
    "destructive": "disposable-app-support-only"
  },
  "suites": {
    "quick": {"budgetMinutes": 10, "includes": ["launch-and-navigation", "model-readiness", "custom-generation", "semantic-review"]},
    "full": {"budgetMinutes": 40, "includes": ["launch-and-navigation", "model-readiness", "custom-generation", "semantic-review", "design-generation", "clone-generation", "batch-generation", "history-and-voices", "settings-round-trip", "reference-import", "xpc-recovery"]},
    "benchmark": {"budgetMinutes": null, "includes": ["model-readiness", "generation-matrix"]},
    "destructive": {"budgetMinutes": null, "requiresExplicitAuthorization": true, "requiresDisposableAppSupport": true, "includes": ["history-deletion", "voice-deletion", "model-lifecycle"]}
  },
  "scenarios": [
    {
      "id": "launch-and-navigation", "title": "Launch and primary navigation", "destructive": false,
      "timeoutSeconds": 60, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot",
      "steps": [
        {"id": "observe-launch", "action": "observe", "target": "screen_customVoice", "semanticResult": "Custom Voice is visible", "deterministicPostcondition": "exact-path-app-process-count=1", "restorationPolicy": "none", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "nav-custom", "action": "activate", "target": "sidebar_customVoice", "semanticResult": "screen_customVoice visible", "deterministicPostcondition": "app-process-alive", "restorationPolicy": "none", "timeoutSeconds": 10, "confirmation": "none"},
        {"id": "nav-design", "action": "activate", "target": "sidebar_voiceDesign", "semanticResult": "screen_voiceDesign visible", "deterministicPostcondition": "app-process-alive", "restorationPolicy": "none", "timeoutSeconds": 10, "confirmation": "none"},
        {"id": "nav-clone", "action": "activate", "target": "sidebar_voiceCloning", "semanticResult": "screen_voiceCloning visible", "deterministicPostcondition": "app-process-alive", "restorationPolicy": "none", "timeoutSeconds": 10, "confirmation": "none"},
        {"id": "nav-history", "action": "activate", "target": "sidebar_history", "semanticResult": "screen_history visible", "deterministicPostcondition": "history-database-readable", "restorationPolicy": "none", "timeoutSeconds": 10, "confirmation": "none"},
        {"id": "nav-voices", "action": "activate", "target": "sidebar_voices", "semanticResult": "screen_voices visible", "deterministicPostcondition": "saved-voice-root-readable", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 10, "confirmation": "none"},
        {"id": "nav-settings", "action": "activate", "target": "sidebar_settings", "semanticResult": "screen_settings visible", "deterministicPostcondition": "preferences-domain-readable", "restorationPolicy": "restore-preferences", "timeoutSeconds": 10, "confirmation": "none"}
      ],
      "probeAssertions": []
    },
    {
      "id": "model-readiness", "title": "Visible model and clone-fixture readiness", "destructive": false,
      "timeoutSeconds": 120, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot",
      "steps": [
        {"id": "open-settings", "action": "activate", "target": "sidebar_settings", "semanticResult": "Settings model downloads are visible", "deterministicPostcondition": "exact-path-app-process-count=1", "restorationPolicy": "none", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "custom-ready", "action": "observe", "target": "settings_packageStatus_pro_custom_speed", "semanticResult": "Custom Speed visibly reports installed and ready", "deterministicPostcondition": "ui-readiness-checkpoint-recorded", "restorationPolicy": "none", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "design-ready", "action": "observe", "target": "settings_packageStatus_pro_design_speed", "semanticResult": "Design Speed visibly reports installed and ready", "deterministicPostcondition": "ui-readiness-checkpoint-recorded", "restorationPolicy": "none", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "clone-ready", "action": "observe", "target": "settings_packageStatus_pro_clone_speed", "semanticResult": "Clone Speed visibly reports installed and ready", "deterministicPostcondition": "ui-readiness-checkpoint-recorded", "restorationPolicy": "none", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "clone-voice-ready", "action": "observeFirst", "targetPrefix": "voicesRow_", "semanticResult": "A saved clone voice is visible before Clone or benchmark generation", "deterministicPostcondition": "ui-readiness-checkpoint-recorded", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 20, "confirmation": "none"}
      ],
      "probeAssertions": []
    },
    {
      "id": "custom-generation", "title": "Custom generation, playback, and History replay", "destructive": false,
      "timeoutSeconds": 300, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot",
      "fixtureText": "Codex macOS quick acceptance generation.",
      "steps": [
        {"id": "open-custom", "action": "activate", "target": "sidebar_customVoice", "semanticResult": "screen_customVoice visible", "deterministicPostcondition": "app-process-alive", "restorationPolicy": "none", "timeoutSeconds": 10, "confirmation": "none"},
        {"id": "compose-custom", "action": "replaceText", "target": "textInput_textEditor", "semanticResult": "character count reflects fixture", "deterministicPostcondition": "fixture-text-digest-recorded", "restorationPolicy": "clear-editor", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "generate-custom", "action": "activate", "target": "textInput_generateButton", "semanticResult": "sidebarPlayer_bar visible and playable", "deterministicPostcondition": "matching-history-wav-and-probes", "restorationPolicy": "debug-history-isolated", "timeoutSeconds": 240, "confirmation": "none"},
        {"id": "play-output", "action": "activate", "target": "sidebarPlayer_playPause", "semanticResult": "player state changes", "deterministicPostcondition": "generated-wav-readable", "restorationPolicy": "stop-playback", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "open-history", "action": "activate", "target": "sidebar_history", "semanticResult": "matching History row visible", "deterministicPostcondition": "matching-history-row", "restorationPolicy": "none", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "replay-history", "action": "activateFirst", "targetPrefix": "historyRow_play_", "semanticResult": "sidebar player replays History item", "deterministicPostcondition": "same-readable-wav", "restorationPolicy": "stop-playback", "timeoutSeconds": 15, "confirmation": "none"}
      ],
      "probeAssertions": ["engine-present", "transport-present", "terminal-match", "chunk-order", "output-readable", "history-match"]
    },
    {
      "id": "semantic-review", "title": "Named semantic visual and accessibility review", "destructive": false,
      "timeoutSeconds": 180, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot",
      "checks": ["no-clipping", "no-truncation", "readable-copy", "enabled-state", "focus-order", "accessibility-labels"],
      "steps": [
        {"id": "review-custom", "action": "review", "target": "screen_customVoice", "semanticResult": "Custom Voice passes named checks", "deterministicPostcondition": "semantic-checkpoint-recorded", "restorationPolicy": "none", "timeoutSeconds": 30, "confirmation": "none"},
        {"id": "review-history", "action": "review", "target": "screen_history", "semanticResult": "History passes named checks", "deterministicPostcondition": "semantic-checkpoint-recorded", "restorationPolicy": "none", "timeoutSeconds": 30, "confirmation": "none"},
        {"id": "review-voices", "action": "review", "target": "screen_voices", "semanticResult": "Saved Voices passes named checks", "deterministicPostcondition": "semantic-checkpoint-recorded", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 30, "confirmation": "none"},
        {"id": "review-settings", "action": "review", "target": "screen_settings", "semanticResult": "Settings passes named checks", "deterministicPostcondition": "semantic-checkpoint-recorded", "restorationPolicy": "restore-preferences", "timeoutSeconds": 30, "confirmation": "none"}
      ],
      "probeAssertions": []
    },
    {
      "id": "design-generation", "title": "Design controls, generation, and save voice", "destructive": false,
      "timeoutSeconds": 360, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot", "fixtureText": "Codex Voice Design acceptance generation.",
      "steps": [
        {"id": "open-design", "action": "activate", "target": "sidebar_voiceDesign", "semanticResult": "screen_voiceDesign visible", "deterministicPostcondition": "app-process-alive", "restorationPolicy": "none", "timeoutSeconds": 10, "confirmation": "none"},
        {"id": "select-brief", "action": "activateFirst", "targetPrefix": "voiceDesign_briefStarter_", "semanticResult": "voice brief populated", "deterministicPostcondition": "brief-length-positive", "restorationPolicy": "clear-brief", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "design-language", "action": "inspectAndChange", "target": "voiceDesign_languageSetup", "semanticResult": "language selection changes", "deterministicPostcondition": "selection-observed", "restorationPolicy": "restore-original-value", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "design-delivery", "action": "inspectAndChange", "target": "voiceDesign_toneSpeed", "semanticResult": "delivery control changes", "deterministicPostcondition": "selection-observed", "restorationPolicy": "restore-original-value", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "compose-design", "action": "replaceText", "target": "textInput_textEditor", "semanticResult": "fixture is present", "deterministicPostcondition": "fixture-text-digest-recorded", "restorationPolicy": "clear-editor", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "generate-design", "action": "activate", "target": "textInput_generateButton", "semanticResult": "player visible", "deterministicPostcondition": "matching-history-wav-and-probes", "restorationPolicy": "debug-history-isolated", "timeoutSeconds": 300, "confirmation": "none"},
        {"id": "save-design-voice", "action": "activate", "target": "voiceDesign_saveVoiceButton", "semanticResult": "save completion state visible", "deterministicPostcondition": "saved-voice-created-in-debug-root", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 30, "confirmation": "none"}
      ],
      "probeAssertions": ["engine-present", "transport-present", "terminal-match", "output-readable"]
    },
    {
      "id": "clone-generation", "title": "Saved-voice handoff and clone generation", "destructive": false,
      "timeoutSeconds": 360, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot", "fixtureText": "Codex Voice Clone acceptance generation.",
      "steps": [
        {"id": "open-voices", "action": "activate", "target": "sidebar_voices", "semanticResult": "Saved Voices visible", "deterministicPostcondition": "voice-root-readable", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "handoff-voice", "action": "activateFirst", "targetPrefix": "voicesRow_use_", "semanticResult": "Voice Cloning opens with active reference", "deterministicPostcondition": "reference-file-readable", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 30, "confirmation": "none"},
        {"id": "compose-clone", "action": "replaceText", "target": "textInput_textEditor", "semanticResult": "fixture is present", "deterministicPostcondition": "fixture-text-digest-recorded", "restorationPolicy": "clear-editor", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "generate-clone", "action": "activate", "target": "textInput_generateButton", "semanticResult": "player visible", "deterministicPostcondition": "matching-history-wav-and-probes", "restorationPolicy": "debug-history-isolated", "timeoutSeconds": 300, "confirmation": "none"}
      ],
      "probeAssertions": ["engine-present", "transport-present", "terminal-match", "output-readable"]
    },
    {
      "id": "batch-generation", "title": "Two-line batch generation", "destructive": false,
      "timeoutSeconds": 480, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot", "fixtureText": "First Codex batch line.\nSecond Codex batch line.",
      "steps": [
        {"id": "open-batch", "action": "activate", "target": "textInput_batchButton", "semanticResult": "batch editor visible", "deterministicPostcondition": "batch-sheet-present", "restorationPolicy": "dismiss-sheet", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "choose-segmentation", "action": "inspectAndRestore", "target": "batch_segmentationMode", "semanticResult": "segmentation control responds", "deterministicPostcondition": "original-segmentation-restored", "restorationPolicy": "restore-original-value", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "compose-batch", "action": "replaceText", "target": "batch_textEditor", "semanticResult": "two lines are present", "deterministicPostcondition": "two-batch-items", "restorationPolicy": "dismiss-sheet", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "generate-batch", "action": "activate", "target": "batch_generateAllButton", "semanticResult": "batch completes", "deterministicPostcondition": "two-matching-history-wavs-and-probes", "restorationPolicy": "debug-history-isolated", "timeoutSeconds": 420, "confirmation": "none"},
        {"id": "close-batch", "action": "activate", "target": "batch_doneButton", "semanticResult": "batch sheet dismissed", "deterministicPostcondition": "app-process-alive", "restorationPolicy": "none", "timeoutSeconds": 20, "confirmation": "none"}
      ],
      "probeAssertions": ["two-generations", "engine-present", "transport-present", "output-readable"]
    },
    {
      "id": "history-and-voices", "title": "History search, sort, replay, save-as-voice, and handoff", "destructive": false,
      "timeoutSeconds": 240, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot",
      "steps": [
        {"id": "open-history", "action": "activate", "target": "sidebar_history", "semanticResult": "History visible", "deterministicPostcondition": "history-database-readable", "restorationPolicy": "none", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "search-history", "action": "replaceText", "target": "history_searchField", "semanticResult": "matching rows filtered", "deterministicPostcondition": "known-row-remains", "restorationPolicy": "clear-search", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "sort-history", "action": "inspectAndRestore", "target": "history_sortPicker", "semanticResult": "row order changes", "deterministicPostcondition": "original-sort-restored", "restorationPolicy": "restore-original-value", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "replay-row", "action": "activateFirst", "targetPrefix": "historyRow_play_", "semanticResult": "player visible", "deterministicPostcondition": "history-wav-readable", "restorationPolicy": "stop-playback", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "save-as-voice", "action": "activateFirst", "targetPrefix": "historyRow_saveVoice_", "semanticResult": "voice saved", "deterministicPostcondition": "saved-voice-file-created", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 45, "confirmation": "none"},
        {"id": "open-saved-voices", "action": "activate", "target": "sidebar_voices", "semanticResult": "saved voice appears", "deterministicPostcondition": "saved-voice-file-readable", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "handoff-saved-voice", "action": "activateFirst", "targetPrefix": "voicesRow_use_", "semanticResult": "Clone opens with active reference", "deterministicPostcondition": "active-reference-readable", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 30, "confirmation": "none"}
      ],
      "probeAssertions": ["history-match"]
    },
    {
      "id": "settings-round-trip", "title": "Reversible settings round trip", "destructive": false,
      "timeoutSeconds": 180, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot",
      "steps": [
        {"id": "open-settings", "action": "activate", "target": "sidebar_settings", "semanticResult": "Settings visible", "deterministicPostcondition": "preferences-domain-readable", "restorationPolicy": "restore-preferences", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "toggle-autoplay", "action": "toggleAndRestore", "target": "preferences_autoPlayToggle", "semanticResult": "toggle changes and returns", "deterministicPostcondition": "original-autoplay-restored", "restorationPolicy": "restore-original-value", "timeoutSeconds": 30, "confirmation": "none"},
        {"id": "change-variation", "action": "changeAndRestore", "target": "settings_generationVariation", "semanticResult": "variation changes and returns", "deterministicPostcondition": "original-variation-restored", "restorationPolicy": "restore-original-value", "timeoutSeconds": 30, "confirmation": "none"}
      ],
      "probeAssertions": []
    },
    {
      "id": "reference-import", "title": "Reference import through the macOS file panel", "destructive": false,
      "timeoutSeconds": 240, "requiresActionTimeConfirmation": true, "restorationPolicy": "cancel-sheet-and-restore-saved-voices", "fixturePath": "scripts/tests/fixtures/prosody/good_01.wav",
      "steps": [
        {"id": "open-clone", "action": "activate", "target": "sidebar_voiceCloning", "semanticResult": "Voice Cloning visible", "deterministicPostcondition": "app-process-alive", "restorationPolicy": "none", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "open-import", "action": "activate", "target": "voiceCloning_importButton", "semanticResult": "system file panel visible", "deterministicPostcondition": "fixture-file-readable", "restorationPolicy": "cancel-panel", "timeoutSeconds": 30, "confirmation": "none"},
        {"id": "choose-fixture", "action": "selectFixture", "target": "system-file-panel", "semanticResult": "tracked non-PII fixture selected", "deterministicPostcondition": "selected-path-digest-matches-fixture", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 90, "confirmation": "action-time"},
        {"id": "verify-reference", "action": "observe", "target": "voiceCloning_activeReference", "semanticResult": "active reference visible", "deterministicPostcondition": "imported-reference-readable", "restorationPolicy": "restore-saved-voices", "timeoutSeconds": 60, "confirmation": "none"}
      ],
      "probeAssertions": []
    },
    {
      "id": "xpc-recovery", "title": "XPC interruption, reconnection, and post-recovery generation", "destructive": false,
      "timeoutSeconds": 480, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot", "fixtureText": "Codex XPC recovery generation.",
      "steps": [
        {"id": "kill-service", "action": "shell", "target": "harness:xpc-kill", "semanticResult": "app survives service kill", "deterministicPostcondition": "app-process-alive-and-service-absent", "restorationPolicy": "service-relaunches-on-demand", "timeoutSeconds": 30, "confirmation": "none"},
        {"id": "open-custom-after-kill", "action": "activate", "target": "sidebar_customVoice", "semanticResult": "Custom Voice remains usable", "deterministicPostcondition": "app-process-alive", "restorationPolicy": "none", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "compose-recovery", "action": "replaceText", "target": "textInput_textEditor", "semanticResult": "fixture is present", "deterministicPostcondition": "fixture-text-digest-recorded", "restorationPolicy": "clear-editor", "timeoutSeconds": 15, "confirmation": "none"},
        {"id": "generate-after-kill", "action": "activate", "target": "textInput_generateButton", "semanticResult": "player visible after recovery", "deterministicPostcondition": "matching-history-wav-reconnection-and-probes", "restorationPolicy": "debug-history-isolated", "timeoutSeconds": 360, "confirmation": "none"},
        {"id": "verify-recovery-probes", "action": "shell", "target": "harness:verify-probes", "semanticResult": "no error or crash marker", "deterministicPostcondition": "interruption-reconnection-terminal-match", "restorationPolicy": "none", "timeoutSeconds": 30, "confirmation": "none"}
      ],
      "probeAssertions": ["transport-interruption", "transport-reconnection", "engine-present", "terminal-match", "output-readable"]
    },
    {
      "id": "generation-matrix", "title": "Ordered 29-take Computer Use generation benchmark", "destructive": false,
      "timeoutSeconds": 10800, "requiresActionTimeConfirmation": false, "restorationPolicy": "restore-snapshot",
      "matrix": {
        "modes": ["custom", "design", "clone"], "lengths": ["short", "medium", "long"], "warmRepetitions": 3,
        "coldLength": "medium", "coldModes": ["custom", "design"],
        "designBrief": "A warm, calm middle-aged male narrator with a clear, measured pace.", "cloneVoice": "A_warm_elderly_woman",
        "corpus": {
          "short": "The train left the station at dawn.",
          "medium": "The morning train slipped quietly out of the station, carrying a handful of sleepy travelers toward the coast.",
          "long": "The morning train slipped quietly out of the station, carrying a handful of sleepy travelers toward the coast. Outside the fogged windows, pale fields gave way to grey water, and the rhythm of the rails settled into a steady, hypnotic hum. By the time the sun finally broke through, most of the passengers had drifted into an unhurried silence."
        }
      },
      "steps": [
        {"id": "drive-ordered-matrix", "action": "benchmarkManifest", "target": "textInput_generateButton", "semanticResult": "all 29 takes are driven in manifest order", "deterministicPostcondition": "29-matching-history-wav-and-probe-records", "restorationPolicy": "restore-snapshot", "timeoutSeconds": 10800, "confirmation": "none"}
      ],
      "probeAssertions": ["matrix-complete", "engine-present", "transport-present", "terminal-match", "chunk-order", "output-readable"]
    },
    {
      "id": "history-deletion", "title": "Disposable History deletion", "destructive": true,
      "timeoutSeconds": 180, "requiresActionTimeConfirmation": true, "restorationPolicy": "discard-disposable-root",
      "steps": [
        {"id": "open-disposable-history", "action": "activate", "target": "sidebar_history", "semanticResult": "isolated History visible", "deterministicPostcondition": "app-support-root-is-disposable", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "delete-disposable-row", "action": "activateFirst", "targetPrefix": "historyRow_delete_", "semanticResult": "disposable row removed", "deterministicPostcondition": "isolated-history-row-absent", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 60, "confirmation": "action-time"}
      ],
      "probeAssertions": ["production-root-untouched"]
    },
    {
      "id": "voice-deletion", "title": "Disposable saved-voice deletion", "destructive": true,
      "timeoutSeconds": 180, "requiresActionTimeConfirmation": true, "restorationPolicy": "discard-disposable-root",
      "steps": [
        {"id": "open-disposable-voices", "action": "activate", "target": "sidebar_voices", "semanticResult": "isolated Saved Voices visible", "deterministicPostcondition": "voice-root-is-disposable", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 20, "confirmation": "none"},
        {"id": "delete-disposable-voice", "action": "activateFirst", "targetPrefix": "voicesRow_delete_", "semanticResult": "disposable voice removed", "deterministicPostcondition": "isolated-voice-files-absent", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 60, "confirmation": "action-time"}
      ],
      "probeAssertions": ["production-root-untouched"]
    },
    {
      "id": "model-lifecycle", "title": "Isolated model cancel, repair, delete, and download", "destructive": true,
      "timeoutSeconds": 3600, "requiresActionTimeConfirmation": true, "restorationPolicy": "discard-disposable-root",
      "steps": [
        {"id": "open-isolated-models", "action": "activate", "target": "sidebar_settings", "semanticResult": "Settings shows isolated model inventory", "deterministicPostcondition": "model-root-is-disposable", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 30, "confirmation": "none"},
        {"id": "start-isolated-download", "action": "activateFirst", "targetPrefix": "settings_download_", "semanticResult": "isolated download begins", "deterministicPostcondition": "staging-files-under-disposable-root", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 120, "confirmation": "action-time"},
        {"id": "cancel-isolated-download", "action": "activateFirst", "targetPrefix": "settings_cancel_", "semanticResult": "download cancels", "deterministicPostcondition": "isolated-download-state-cancelled", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 120, "confirmation": "action-time"},
        {"id": "repair-isolated-model", "action": "activateFirst", "targetPrefix": "settings_repair_", "semanticResult": "isolated repair begins", "deterministicPostcondition": "repair-writes-only-disposable-root", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 900, "confirmation": "action-time"},
        {"id": "delete-isolated-model", "action": "activateFirst", "targetPrefix": "settings_manage_", "semanticResult": "isolated model is deleted", "deterministicPostcondition": "isolated-model-files-absent", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 120, "confirmation": "action-time"},
        {"id": "download-isolated-model", "action": "activateFirst", "targetPrefix": "settings_download_", "semanticResult": "isolated model reaches installed", "deterministicPostcondition": "verified-model-files-under-disposable-root", "restorationPolicy": "discard-disposable-root", "timeoutSeconds": 1800, "confirmation": "action-time"}
      ],
      "probeAssertions": ["production-root-untouched"]
    }
  ]
}
