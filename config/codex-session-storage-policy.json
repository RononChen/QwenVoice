{
  "schemaVersion": 1,
  "id": "codex-session-storage",
  "owner": "release-qa",
  "status": "optional-local-operator-workflow",
  "scope": {
    "repositoryOwnsUserState": false,
    "ciMayInspectUserState": false,
    "coveredStores": {
      "active": "sessions",
      "archived": "archived_sessions"
    },
    "rolloutFilenamePatterns": [
      "rollout-*.jsonl",
      "rollout-*.jsonl.zst"
    ],
    "rejectUnexpectedJsonlFilenames": true,
    "requireFilenameSessionIdMatch": true,
    "rejectSymlinkedStoreDirectories": true,
    "requireUniqueRegularRolloutFiles": true,
    "excludedState": [
      "config",
      "databases",
      "memories",
      "plugins",
      "skills",
      "packages",
      "logs",
      "attachments",
      "generated-images",
      "repository-build-output",
      "models",
      "benchmark-history"
    ]
  },
  "metadata": {
    "recordType": "session_meta",
    "maximumFirstLineBytes": 4194304,
    "allowedRecordFields": [
      "type",
      "timestamp",
      "payload"
    ],
    "allowedPayloadFields": [
      "id",
      "session_id",
      "parent_thread_id",
      "timestamp",
      "cwd",
      "source.subagent.thread_spawn.parent_thread_id"
    ],
    "readLaterJsonlLines": false,
    "requireTerminatingNewline": true,
    "compressedRolloutReader": "python-stdlib-compression.zstd",
    "compressedReaderUnavailable": "fail-closed",
    "includeTaskNames": false
  },
  "privacy": {
    "trackedRuntimeRecordsAllowed": false,
    "operatorRecordsLocation": "system-temporary-directory",
    "operatorRecordsMode": "0600",
    "operatorRecordsDirectoryMode": "0700",
    "forbiddenTrackedData": [
      "session-identifiers",
      "rollout-filenames",
      "absolute-paths",
      "usernames",
      "task-titles",
      "prompts",
      "transcripts",
      "tool-output",
      "images",
      "secrets",
      "private-metadata"
    ]
  },
  "classification": {
    "defaultDisposition": "protect",
    "deleteOnlyProvenDescendants": true,
    "ambiguousDisposition": "protect",
    "requireExplicitProtectedRoot": true,
    "blockTargetAdjacentAmbiguity": true,
    "deriveDepthFromParentChain": true
  },
  "execution": {
    "automaticDeletion": false,
    "commandTemplate": [
      "codex",
      "delete",
      "--force",
      "{sessionId}"
    ],
    "assumeCommandCascades": false,
    "order": "deepest-first-root-last",
    "requireManifestSha256": true,
    "requireApprovedRoot": true,
    "planValiditySeconds": 86400,
    "requireCurrentValidityWindow": true,
    "revalidateBeforeMutation": true,
    "preMutationScans": 2,
    "verifyAfterEachDeletion": true,
    "requireLeafBeforeEachDeletion": true,
    "preserveBaselineNonTargets": true,
    "rejectReferencesToAnyApprovedId": true,
    "sameDepthTieBreak": "session-id-ascending",
    "commandTimeoutSeconds": 120,
    "persistCommandOutput": false,
    "shell": false
  },
  "measurement": {
    "fileLogicalBytes": "stat.st_size",
    "fileAllocatedBytes": "stat.st_blocks*512",
    "filesystemAvailableBytes": "statvfs",
    "directoryCrossChecks": [
      "du-apparent",
      "du-allocated",
      "df-available"
    ],
    "mole": {
      "required": false,
      "allowedMode": "analyze-only",
      "authority": "supplemental-only",
      "mayAuthorizeDeletion": false
    }
  },
  "continuity": {
    "recommendNewTopLevelTaskAtMajorCheckpoint": true,
    "requireExplicitOperatorRequestForTaskCreation": true,
    "subagentContext": "smallest-bounded-self-contained-brief",
    "fullHistoryForkDefault": false,
    "preferEphemeralExecForDisposableWork": true,
    "repositoryTruth": [
      "committed-code",
      "machine-readable-contracts",
      "docs/development-progress.md"
    ]
  },
  "integration": {
    "manualOnly": true,
    "developmentGate": false,
    "publicationGate": false,
    "releaseEvidenceInput": false,
    "scheduledAutomation": false,
    "ciPolicyCommand": "python3 scripts/codex_session_storage.py validate",
    "ciSyntheticTestCommand": "python3 -m unittest scripts.tests.test_codex_session_storage"
  }
}
