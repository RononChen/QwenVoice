  "referencePolicy": {
    "scanRoots": [
      "AGENTS.md",
      ".agents",
      ".github",
      ".xcodebuildmcp",
      "README.md",
      "benchmarks",
      "config",
      "docs",
      "project.yml",
      "scripts",
      "Sources/Resources/voice-previews/README.md",
      "website"
    ],
    "excludePrefixes": [
      "benchmarks/HISTORY.md",
      "benchmarks/LEGACY_HISTORY.md",
      "benchmarks/runs",
      "config/build-output-policy.json",
      "docs/releases",
      "scripts/tests"
    ],
    "retiredPrefixes": [
      "build/DerivedData",
      "build/source-packages",
      "build/foundation",
      "build/ui-tests",
      "build/macos",
      "build/ios/",
      "build/ios-diagnostics",
      "build/ios-logs",
      "build/TelemetryAuditDerivedData",
      "build/DerivedData-ios-memory",
      "build/DerivedData-memory-failure",
