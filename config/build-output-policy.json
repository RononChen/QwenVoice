      "build/xctrace-signpost-probe",
      "third_party_patches/mlx-audio-swift/.build",
      "Packages/VocelloQwen3Core/.build"
    ],
    "retiredFragments": [
      "$BUILD_DIR/DerivedData",
      "${BUILD_DIR}/DerivedData",
      "$BUILD_DIR/source-packages",
      "${BUILD_DIR}/source-packages",
      "$BUILD_DIR/foundation",
      "${BUILD_DIR}/foundation",
      "$BUILD_DIR/ui-tests",
      "${BUILD_DIR}/ui-tests",
      "$BUILD_DIR/macos",
      "${BUILD_DIR}/macos",
      "$BUILD_DIR/ios",
      "${BUILD_DIR}/ios",
      "$BUILD_DIR/ios-diagnostics",
      "${BUILD_DIR}/ios-diagnostics",
      "$BUILD_DIR/ios-logs",
      "${BUILD_DIR}/ios-logs",
      "$BUILD_DIR/TelemetryAuditDerivedData",
      "${BUILD_DIR}/TelemetryAuditDerivedData",
      "$BUILD_DIR/DerivedData-ios-memory",
      "${BUILD_DIR}/DerivedData-ios-memory",
      "$BUILD_DIR/DerivedData-memory-failure",
      "${BUILD_DIR}/DerivedData-memory-failure"
    ]
  }
}
