    },
    {
      "id": "legacy-xctrace-combined-interval-export",
      "source": "build/xctrace-combined-probe-os-signpost-interval.xml",
      "destination": "build/scratch/transient/legacy-profile-probes/xctrace-combined-probe-os-signpost-interval.xml"
    },
    {
      "id": "legacy-xctrace-combined-signpost-export",
      "source": "build/xctrace-combined-probe-os-signpost.xml",
      "destination": "build/scratch/transient/legacy-profile-probes/xctrace-combined-probe-os-signpost.xml"
    },
    {
      "id": "legacy-xctrace-combined-time-export",
      "source": "build/xctrace-combined-probe-time-profile.xml",
