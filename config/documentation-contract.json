      "reviewTriggers": ["vendor source changes", "dependency pins", "upstream review", "performance semantics"],
      "paths": ["third_party_patches/mlx-audio-swift/README.md", "third_party_patches/mlx-audio-swift/UPSTREAM.md", "third_party_patches/mlx-audio-swift/PERFORMANCE.md", "third_party_patches/mlx-audio-swift/CLONE_ARTIFACT_FORMAT.md"]
    },
    {
      "id": "generated",
      "title": "Generated indexes",
      "status": "generated",
      "owner": "release-qa",
      "authority": "generators",
      "audience": "maintainers",
      "reviewTriggers": ["source manifest or benchmark record changes"],
