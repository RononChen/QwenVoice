<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  App Store export options for the VocelloiOS archive (the signed-IPA / TestFlight lane).

  Used by:  xcodebuild -exportArchive -archivePath … -exportOptionsPlist ExportOptions-appstore.plist
  Produces: an App-Store-Connect-uploadable .ipa.

  teamID is intentionally NOT committed (maintainer-privacy rule — no hardcoded Apple
  team IDs in tracked files). Copy this template to a governed scratch path, then inject it there:
      cp ExportOptions-appstore.plist build/scratch/transient/ios-release/ExportOptions-appstore.plist
      /usr/libexec/PlistBuddy -c "Add :teamID string $YOUR_TEAM_ID" build/scratch/transient/ios-release/ExportOptions-appstore.plist
  Never mutate the tracked template. The archive-ios CI job does this from the
  QWENVOICE_DEVELOPMENT_TEAM secret. With automatic
  signing + a logged-in single-team Xcode, a local maintainer export resolves the team without it.

  Signing: signingStyle=automatic relies on -allowProvisioningUpdates (CI authenticates with the
  App Store Connect API key). The provisioning profile MUST carry the
  com.apple.developer.kernel.increased-memory-limit capability, or the model load is Jetsam-killed
  on the signed build. See docs/reference/ios-appstore-submission.md.
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store-connect</string>
    <key>destination</key>
    <string>export</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>manageAppVersionAndBuildNumber</key>
    <false/>
    <key>stripSwiftSymbols</key>
    <true/>
    <key>uploadSymbols</key>
    <true/>
    <key>testFlightInternalTestingOnly</key>
    <false/>
</dict>
</plist>
