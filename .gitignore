# Owned monorepo packages. Other ad hoc package checkouts remain local-only.
Packages/*
!Packages/VocelloQwen3Core/
!Packages/VocelloQwen3Core/**

# Release build output
build/

# Git worktrees
.worktrees/

# Stale build logs
build_log*.txt

# Code coverage artifacts
*.profraw
.vercel

# Benchmark / diagnostics logs: commit only compact summaries under benchmarks/
# (guard-enforced <=256 KB). Raw telemetry JSONL stays out of git — it lives on
# disk under ~/Library/.../QwenVoice[-Debug]/diagnostics and auto-prunes.
benchmarks/**/*.jsonl
benchmarks/**/*.ndjson
benchmarks/**/*.jsonlines
benchmarks/**/*.log
benchmarks/**/*.ips
benchmarks/**/*.tracev3
benchmarks/**/*.wav
benchmarks/**/*.wave
benchmarks/**/*.aif
benchmarks/**/*.aiff
benchmarks/**/*.caf
benchmarks/**/*.flac
benchmarks/**/*.mp3
benchmarks/**/*.m4a
benchmarks/**/*.ogg
benchmarks/**/*.opus
benchmarks/**/*.png
benchmarks/**/*.jpg
benchmarks/**/*.jpeg
benchmarks/**/*.gif
benchmarks/**/*.heic
benchmarks/**/*.heif
benchmarks/**/*.tif
benchmarks/**/*.tiff
benchmarks/**/*.webp
benchmarks/**/*.bmp
benchmarks/**/*.xcresult/
benchmarks/**/*.trace/
benchmarks/**/*.xcarchive/
benchmarks/**/*.dSYM/
samples-*.jsonl
**/diagnostics/
